# Primary provider — get a free key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_real_gemini_api_key_here

# Optional fallback provider — used automatically if Gemini is overloaded,
# rate-limited, or down. Get a free key at https://console.groq.com/keys
# (leave as-is / omit if you don't want a fallback provider).
VITE_GROQ_API_KEY=your_real_groq_api_key_here

# Copy this file to ".env" and paste your real key(s) in above.
# NEVER commit the real ".env" file — it is already in .gitignore.
